---
import navigationData from '../../data/navigation.json';
import './navigation.css';

interface Props {
  lang: 'zh' | 'en';
  currentPath: string;
}

const { lang = 'zh', currentPath = '' } = Astro.props;
const navItems = navigationData[lang].nav;

function isActive(href: string, path: string): boolean {
  if (href === `/${lang}/` || href === `/${lang}`) {
    return path === `/${lang}/` || path === `/${lang}` || path === '/';
  }
  return path.startsWith(href);
}
---

<header class="nav-header">
  <nav class="nav-container">
    <a href={`/${lang}/`} class="nav-logo">
      <span class="nav-logo-text">Spec-First</span>
    </a>

    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <ul class="nav-menu">
      {navItems.map((item) => (
        <li class="nav-item">
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.href, currentPath) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-lang-switch">
      <a
        href={currentPath.replace(/^\/(zh|en)/, lang === 'zh' ? '/en' : '/zh')}
        class="nav-lang-link"
      >
        {lang === 'zh' ? 'EN' : '中文'}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.querySelector('.nav-menu');

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('nav-menu-open');
    toggle.classList.toggle('nav-toggle-active');
  });
</script>

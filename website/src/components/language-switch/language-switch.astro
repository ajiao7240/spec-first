---
interface Props {
  lang: 'zh' | 'en';
  currentPath: string;
}

const { lang = 'zh', currentPath = '' } = Astro.props;

// Calculate the alternate language path
const alternateLang = lang === 'zh' ? 'en' : 'zh';
const alternatePath = currentPath.replace(/^\/(zh|en)/, `/${alternateLang}`);
---

<div class="lang-switch">
  <a
    href={alternatePath}
    class="lang-switch-link"
    data-current-lang={lang}
  >
    {lang === 'zh' ? 'EN' : '中文'}
  </a>
</div>

<style>
  .lang-switch {
    display: flex;
    align-items: center;
  }

  .lang-switch-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-light);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    min-width: 48px;
  }

  .lang-switch-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background-color: var(--color-bg-alt);
  }
</style>

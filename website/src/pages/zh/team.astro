---
import BaseLayout from '../../layouts/base-layout.astro';
import teamData from '../../data/team.json';

const { title, subtitle, members, contributors } = teamData.zh;
---

<BaseLayout title="团队" lang="zh">
  <section class="team-hero container">
    <h1 class="team-title">{title}</h1>
    <p class="team-subtitle">{subtitle}</p>
  </section>

  <section class="team-members container">
    <div class="grid grid-3">
      {members.map((member) => (
        <div class="card member-card">
          <div class="member-avatar">
            <img
              src={`https://github.com/${member.github}.png?size=128`}
              alt={member.name}
              loading="lazy"
            />
          </div>
          <h3 class="member-name">{member.name}</h3>
          <p class="member-role">{member.role}</p>
          <p class="member-bio">{member.bio}</p>
          <a
            href={`https://github.com/${member.github}`}
            target="_blank"
            rel="noopener"
            class="member-github"
          >
            @{member.github}
          </a>
        </div>
      ))}
    </div>
  </section>

  <section class="contributors-section container">
    <h2 class="section-title">{contributors.title}</h2>
    <p class="contributors-description">{contributors.description}</p>
    <a
      href="https://github.com/kuangp/spec-first/graphs/contributors"
      target="_blank"
      rel="noopener"
      class="btn btn-primary"
    >
      {contributors.cta}
    </a>
  </section>
</BaseLayout>

<style>
  .team-hero {
    padding: var(--spacing-3xl) var(--spacing-md);
    text-align: center;
  }

  .team-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: var(--spacing-md);
  }

  .team-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .team-members {
    padding: var(--spacing-2xl) var(--spacing-md);
  }

  .member-card {
    text-align: center;
    padding: var(--spacing-xl);
  }

  .member-avatar {
    width: 96px;
    height: 96px;
    margin: 0 auto var(--spacing-md);
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-primary-light);
  }

  .member-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-name {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }

  .member-role {
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: var(--spacing-sm);
  }

  .member-bio {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
  }

  .member-github {
    font-size: 0.875rem;
    color: var(--color-text-light);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .member-github:hover {
    color: var(--color-primary);
  }

  .contributors-section {
    padding: var(--spacing-3xl) var(--spacing-md);
    text-align: center;
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-xl);
    margin: var(--spacing-2xl) auto;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--spacing-md);
  }

  .contributors-description {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-xl);
  }

  @media (max-width: 767px) {
    .team-title {
      font-size: 2rem;
    }
  }
</style>

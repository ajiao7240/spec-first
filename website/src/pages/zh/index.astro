---
import BaseLayout from '../../layouts/base-layout.astro';
import HeroSection from '../../components/hero-section/hero-section.astro';
import FeatureCards from '../../components/feature-cards/feature-cards.astro';
import TerminalDemo from '../../components/terminal-demo/terminal-demo.astro';

const features = [
  {
    title: '阶段状态机',
    description: '8 个活动阶段 + 2 个终止状态，单向不可逆，确保流程规范。',
  },
  {
    title: '追溯 ID',
    description: '14 类 ID 覆盖业务链路和 V-Model，实现规范到实现的完整追溯。',
  },
  {
    title: 'Gate 质量门禁',
    description: '19 条校验规则（16 条阻塞 + 3 条警告），阶段推进前强制质量保障。',
  },
  {
    title: 'Skill 编排',
    description: '20+ AI 驱动的 Skill 覆盖全生命周期，智能引导研发流程。',
  },
];
---

<BaseLayout title="首页" lang="zh">
  <HeroSection
    title="Spec-First"
    subtitle="规范驱动开发的 AI 工作流引擎"
    description="从需求到上线，阶段状态机驱动的全链路研发闭环。每个实现可追溯到对应规范定义，规范可被自动化校验。"
    primaryAction={{ label: '了解更多', href: '/zh/product' }}
    secondaryAction={{ label: 'GitHub', href: 'https://github.com/kuangp/spec-first' }}
  />
  <TerminalDemo lang="zh" />
  <FeatureCards title="核心特性" features={features} />
</BaseLayout>

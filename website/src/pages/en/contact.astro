---
import BaseLayout from '../../layouts/base-layout.astro';
---

<BaseLayout title="Contact" lang="en">
  <section class="contact-hero container">
    <h1 class="contact-title">Contact Us</h1>
    <p class="contact-subtitle">Have questions or suggestions? We'd love to hear from you</p>
  </section>

  <section class="contact-methods container">
    <div class="grid grid-2">
      <a
        href="https://github.com/kuangp/spec-first/issues"
        target="_blank"
        rel="noopener"
        class="card contact-card"
      >
        <div class="contact-icon">🐛</div>
        <h3>GitHub Issues</h3>
        <p>Report bugs, suggest features, or join discussions</p>
        <span class="contact-link">github.com/kuangp/spec-first/issues →</span>
      </a>

      <a
        href="mailto:contact@spec-first.dev"
        class="card contact-card"
      >
        <div class="contact-icon">📧</div>
        <h3>Email</h3>
        <p>Business inquiries or non-technical questions</p>
        <span class="contact-link">contact@spec-first.dev →</span>
      </a>
    </div>
  </section>

  <section class="community-section container">
    <h2 class="section-title">Join the Community</h2>
    <div class="grid grid-2">
      <a
        href="https://github.com/kuangp/spec-first"
        target="_blank"
        rel="noopener"
        class="card community-card"
      >
        <h4>GitHub</h4>
        <p>View source code, star the repo</p>
      </a>

      <a
        href="https://github.com/kuangp/spec-first/discussions"
        target="_blank"
        rel="noopener"
        class="card community-card"
      >
        <h4>Discussions</h4>
        <p>Join community discussions</p>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: var(--spacing-3xl) var(--spacing-md);
    text-align: center;
  }

  .contact-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: var(--spacing-md);
  }

  .contact-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-methods {
    padding: var(--spacing-2xl) var(--spacing-md);
  }

  .contact-card {
    text-decoration: none;
    color: inherit;
    text-align: center;
    padding: var(--spacing-2xl);
    transition: all var(--transition-fast);
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .contact-icon {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
  }

  .contact-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
  }

  .contact-card p {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
  }

  .contact-link {
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
  }

  .community-section {
    padding: var(--spacing-2xl) var(--spacing-md);
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .community-card {
    text-decoration: none;
    color: inherit;
    padding: var(--spacing-lg);
    text-align: center;
  }

  .community-card h4 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }

  .community-card p {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  @media (max-width: 767px) {
    .contact-title {
      font-size: 2rem;
    }
  }
</style>

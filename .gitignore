# Generated spec-first local config and workflow runtime artifacts
# These files are runtime facts; verify presence/schema with setup scripts, not git status.
.spec-first/config.local.yaml
.spec-first/verification-profile.local.json
.spec-first/config/*.json
.spec-first/audits/
.spec-first/governance/
.spec-first/app-audit/
.spec-first/workflows/
.spec-first/workspace/
.spec-first/sessions/
.spec-first/ci/
.spec-first/cache/
.spec-first/tools/

# Provider runtime data (CodeGraph daemon db/log) — runtime facts, not source
.codegraph/

# Published/package artifacts
*.tgz

# Python artifacts
__pycache__/
*.pyc
*.pyo


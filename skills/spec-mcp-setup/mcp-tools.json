{
  "schema_version": "2",
  "summary_columns": [
    "tool",
    "required",
    "dependency",
    "host_config",
    "project_bootstrap",
    "result",
    "next_action"
  ],
  "tools": [
    {
      "id": "serena",
      "name": "Serena",
      "summary_label": "Serena",
      "required": true,
      "description": "符号级精确编辑引擎，spec-first 全工作流与 graph bootstrap 增强模式依赖",
      "dependencies": ["uv"],
      "installation": {
        "kind": "warmup",
        "unix": {
          "command": "uvx",
          "args": ["--from", "git+https://github.com/oraios/serena", "serena", "--help"]
        },
        "windows": {
          "command": "uvx",
          "args": ["--from", "git+https://github.com/oraios/serena", "serena", "--help"]
        }
      },
      "host_config": {
        "claude": {
          "command": "uvx",
          "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--project-from-cwd", "--context", "ide-assistant", "--open-web-dashboard", "false"],
          "scope": "user"
        },
        "codex": {
          "command": "uvx",
          "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--project-from-cwd", "--context", "codex", "--open-web-dashboard", "false"],
          "startup_timeout_sec": 90,
          "scope": "user"
        }
      },
      "detection": {
        "kind": "host_config_exact",
        "key": "serena"
      },
      "project_bootstrap": {
        "kind": "serena",
        "required": true,
        "project_file": ".serena/project.yml",
        "ready_marker_file": ".serena/index-ready.json",
        "index_command": {
          "command": "uvx",
          "args": ["--from", "git+https://github.com/oraios/serena", "serena", "project", "index"]
        }
      }
    },
    {
      "id": "sequential-thinking",
      "name": "Sequential Thinking",
      "summary_label": "Sequential Thinking",
      "required": true,
      "description": "动态反思性问题解决，spec-first 全工作流通用依赖",
      "dependencies": ["node"],
      "installation": {
        "kind": "warmup",
        "unix": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-sequential-thinking", "--help"]
        },
        "windows": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-sequential-thinking", "--help"]
        }
      },
      "host_config": {
        "claude": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
          "scope": "user"
        },
        "codex": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
          "scope": "user"
        }
      },
      "detection": {
        "kind": "host_config_exact",
        "key": "sequential-thinking"
      },
      "project_bootstrap": {
        "kind": "none",
        "required": false
      }
    },
    {

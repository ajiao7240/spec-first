{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/audit-report.schema.json",
  "title": "spec-app-consistency-audit final report artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "generated_at",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "summary",
    "scope_and_degraded_modes",
    "issues"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-report.v1" },
    "artifact_id": { "const": "audit-report" },
    "generated_at": { "type": "string" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "contract_status": { "enum": ["candidate", "confirmed"] },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "summary": { "type": "object" },
    "scope_and_degraded_modes": { "type": "array" },
    "issues": { "type": "array" }
  },
  "additionalProperties": true
}

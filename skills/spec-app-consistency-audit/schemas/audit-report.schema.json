{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/audit-report.schema.json",
  "title": "spec-app-consistency-audit final report artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "generated_at",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "summary",
    "scope_and_degraded_modes",
    "issues",
    "rejected_issues"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-report.v1" },
    "artifact_id": { "const": "audit-report" },
    "generated_at": { "type": "string" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "contract_status": { "enum": ["candidate", "confirmed"] },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "summary": { "type": "object" },
    "scope_and_degraded_modes": { "type": "array" },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/audit_issue" }
    },
    "rejected_issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/audit_issue" }
    }
  },
  "$defs": {
    "audit_issue": {
      "type": "object",
      "required": [
        "id",
        "title",
        "severity",
        "category",
        "claim_family",
        "claim_type",
        "affected_surface",
        "expert",
        "contract_status",
        "confidence",
        "impact",
        "recommendation",
        "data_sensitivity",
        "static_confirmed",
        "requires_runtime_verification",
        "requires_real_device",
        "provenance",
        "evidence",
        "related_rule_packs",
        "runtime_verification",
        "validation_status",
        "review_lifecycle"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "severity": { "enum": ["blocker", "high", "medium", "low", "info"] },
        "category": { "type": "string", "minLength": 1 },
        "claim_family": { "type": "string", "minLength": 1 },
        "claim_type": { "type": "string", "minLength": 1 },
        "affected_surface": {
          "type": "object",
          "required": ["type", "id", "file"]
        },
        "expert": { "type": "string", "minLength": 1 },
        "contract_status": { "enum": ["candidate", "confirmed", "rejected"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "impact": { "$ref": "#/$defs/string_array" },
        "recommendation": { "$ref": "#/$defs/string_array" },
        "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
        "static_confirmed": { "type": "boolean" },
        "requires_runtime_verification": { "type": "boolean" },
        "requires_real_device": { "type": "boolean" },
        "provenance": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_entry" }
        },
        "evidence": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/evidence_entry" }
            },
            {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/evidence_entry" }
              }
            }
          ]
        },
        "related_rule_packs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "runtime_verification": {
          "type": "object",
          "minProperties": 1
        },
        "validation_status": { "enum": ["not_required", "validated", "validator_rejected", "validator_unavailable"] },
        "review_lifecycle": { "type": "array", "minItems": 1 }
      },
      "additionalProperties": true
    },
    "evidence_entry": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/rule-pack-selection.schema.json",
  "title": "spec-app-consistency-audit rule pack selection artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "selected_rule_packs", "confirmed_issue_policy"],
  "properties": {
    "schema_version": { "const": "rule-pack-selection.v1" },
    "artifact_id": { "const": "rule-pack-selection" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "selected_rule_packs": { "type": "array" },
    "confirmed_issue_policy": { "type": "object" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/kmp-architecture-contract.schema.json",
  "title": "spec-app-consistency-audit KMP architecture contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "source_sets", "layers", "source_imports", "boundary_candidates"],
  "properties": {
    "schema_version": { "const": "kmp-architecture-contract.v1" },
    "artifact_id": { "const": "kmp-architecture-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "source_sets": { "type": "array" },
    "layers": { "type": "array" },
    "source_imports": { "type": "array" },
    "boundary_candidates": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/product-contract.schema.json",
  "title": "spec-app-consistency-audit product contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "features", "pages", "degraded_modes"],
  "properties": {
    "schema_version": { "const": "product-contract.v1" },
    "artifact_id": { "const": "product-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "features": { "type": "array" },
    "pages": { "type": "array" },
    "journeys": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

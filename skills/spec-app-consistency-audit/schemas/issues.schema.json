{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/issues.schema.json",
  "title": "spec-app-consistency-audit issues artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "issues",
    "rejected_issues"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-issues.v1" },
    "artifact_id": { "const": "issues" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "issues": {
      "type": "array",
      "items": { "$ref": "issue.schema.json" }
    },
    "rejected_issues": {
      "type": "array",
      "items": { "$ref": "issue.schema.json" }
    }
  },
  "additionalProperties": true
}

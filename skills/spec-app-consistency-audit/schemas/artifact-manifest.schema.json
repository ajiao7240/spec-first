{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/artifact-manifest.schema.json",
  "title": "spec-app-consistency-audit artifact manifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "generated_at",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "run_id",
    "run_dir",
    "artifact_count",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-artifact-manifest.v1" },
    "artifact_id": { "const": "artifact-manifest" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "run_id": { "type": "string", "minLength": 1 },
    "run_dir": { "type": "string", "minLength": 1 },
    "artifact_count": { "type": "number", "minimum": 0 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "schema_version",
          "artifact_id",
          "producer",
          "consumers",
          "sha256",
          "freshness",
          "data_sensitivity",
          "contract_status"
        ]
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/app-audit-context.schema.json",
  "title": "spec-app-consistency-audit assembled context artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "generated_at",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "artifacts_dir",
    "artifact_count",
    "artifacts",
    "validation",
    "valid",
    "degraded_modes"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-context.v1" },
    "artifact_id": { "const": "app-audit-context" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "artifacts_dir": { "type": "string", "minLength": 1 },
    "artifact_count": { "type": "number", "minimum": 0 },
    "artifacts": { "type": "array" },
    "validation": { "type": "array" },
    "valid": { "type": "boolean" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

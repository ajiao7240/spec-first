{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/codebase-contract.schema.json",
  "title": "spec-app-consistency-audit codebase contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "screens", "routes", "view_models"],
  "properties": {
    "schema_version": { "const": "codebase-contract.v1" },
    "artifact_id": { "const": "codebase-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "screens": { "type": "array" },
    "routes": { "type": "array" },
    "view_models": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

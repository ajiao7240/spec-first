{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/merged-app-audit-context.schema.json",
  "title": "spec-app-consistency-audit merged context artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "artifacts", "coverage"],
  "properties": {
    "schema_version": { "const": "merged-app-audit-context.v1" },
    "artifact_id": { "const": "merged-app-audit-context" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "artifacts": { "type": "array" },
    "coverage": { "type": "object" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

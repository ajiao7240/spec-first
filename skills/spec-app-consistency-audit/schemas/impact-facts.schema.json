{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/impact-facts.schema.json",
  "title": "spec-app-consistency-audit impact facts artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "generated_at",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "mode",
    "diff_scope",
    "changed_files",
    "candidate_signals",
    "interaction_surface_changed",
    "available_context",
    "coverage_capabilities",
    "input_expectations",
    "audit_verdict_scope",
    "degraded_modes"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-impact-facts.v1" },
    "artifact_id": { "const": "impact-facts" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "mode": { "enum": ["default", "headless", "report-only"] },
    "diff_scope": { "type": "object" },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "candidate_signals": { "type": "array" },
    "interaction_surface_changed": { "type": "array" },
    "available_context": { "type": "object" },
    "coverage_capabilities": { "type": "object" },
    "input_expectations": { "type": "object" },
    "audit_verdict_scope": {
      "enum": ["source_only_app_static_audit", "product_design_consistency_audit", "full_app_consistency_audit"]
    },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/audit-plan.schema.json",
  "title": "spec-app-consistency-audit LLM audit plan artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "mode",
    "planner_guardrails",
    "planner_decisions",
    "selected_experts",
    "skipped_experts"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-plan.v1" },
    "artifact_id": { "const": "audit-plan" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "mode": { "enum": ["default", "headless", "report-only"] },
    "planner_guardrails": { "type": "object" },
    "planner_decisions": { "type": "array" },
    "selected_experts": { "type": "array" },
    "skipped_experts": { "type": "array" }
  },
  "additionalProperties": true
}

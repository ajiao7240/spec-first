{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/engineering-quality-contract.schema.json",
  "title": "spec-app-consistency-audit engineering quality contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "candidate_count", "candidates"],
  "properties": {
    "schema_version": { "const": "engineering-quality-contract.v1" },
    "artifact_id": { "const": "engineering-quality-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "candidate_count": { "type": "number" },
    "candidates": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/metadata.schema.json",
  "title": "spec-app-consistency-audit run metadata artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "generated_at",
    "source_inputs",
    "consumers",
    "contract_status",
    "data_sensitivity",
    "run_id",
    "host",
    "mode",
    "head_sha",
    "diff_hash",
    "diff_scope_kind",
    "worktree_fingerprint",
    "coverage_capabilities",
    "input_expectations",
    "audit_verdict_scope",
    "run_dir",
    "summary_path",
    "issues_path"
  ],
  "properties": {
    "schema_version": { "const": "spec-app-consistency-audit-metadata.v1" },
    "artifact_id": { "const": "metadata" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "host": { "enum": ["unknown", "claude", "codex"] },
    "mode": { "enum": ["default", "headless", "report-only"] },
    "diff_scope_kind": { "enum": ["git_diff", "working_tree", "source_snapshot"] },
    "coverage_capabilities": { "type": "object" },
    "input_expectations": { "type": "object" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/component-contract.schema.json",
  "title": "spec-app-consistency-audit component contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "code_components", "figma_components", "component_mappings"],
  "properties": {
    "schema_version": { "const": "component-contract.v1" },
    "artifact_id": { "const": "component-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "code_components": { "type": "array" },
    "figma_components": { "type": "array" },
    "component_mappings": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

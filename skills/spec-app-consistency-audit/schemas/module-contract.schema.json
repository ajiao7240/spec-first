{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/module-contract.schema.json",
  "title": "spec-app-consistency-audit module contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "modules", "dependencies", "dependency_cycles", "dependency_metrics", "boundary_candidates"],
  "properties": {
    "schema_version": { "const": "module-contract.v1" },
    "artifact_id": { "const": "module-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "modules": { "type": "array" },
    "dependencies": { "type": "array" },
    "dependency_cycles": { "type": "array" },
    "dependency_metrics": { "type": "array" },
    "boundary_candidates": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/figma-design-contract.schema.json",
  "title": "spec-app-consistency-audit Figma design contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "screens", "components"],
  "properties": {
    "schema_version": { "const": "figma-design-contract.v1" },
    "artifact_id": { "const": "figma-design-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "raw_label_policy": { "enum": ["strict", "internal", "none"] },
    "figma_context_mode": { "enum": ["none", "mcp_reference_only", "materialized_json"] },
    "screens": { "type": "array" },
    "components": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

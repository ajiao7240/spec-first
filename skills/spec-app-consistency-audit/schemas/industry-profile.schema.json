{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/industry-profile.schema.json",
  "title": "spec-app-consistency-audit industry profile artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "preview_only", "industry_candidates"],
  "properties": {
    "schema_version": { "const": "industry-profile.v1" },
    "artifact_id": { "const": "industry-profile" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "preview_only": { "const": true },
    "industry_candidates": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

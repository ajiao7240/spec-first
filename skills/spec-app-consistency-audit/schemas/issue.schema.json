{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/issue.schema.json",
  "title": "spec-app-consistency-audit strict issue",
  "type": "object",
  "required": [
    "id",
    "title",
    "severity",
    "category",
    "claim_family",
    "claim_type",
    "affected_surface",
    "expert",
    "confidence",
    "contract_status",
    "data_sensitivity",
    "static_confirmed",
    "requires_runtime_verification",
    "requires_real_device",
    "provenance",
    "evidence",
    "impact",
    "recommendation",
    "related_rule_packs",
    "runtime_verification",
    "validation_status",
    "review_lifecycle"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "severity": { "enum": ["blocker", "high", "medium", "low", "info"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "contract_status": { "enum": ["candidate", "confirmed", "rejected"] },
    "validation_status": { "enum": ["not_required", "validated", "validator_rejected", "validator_unavailable"] },
    "impact": { "type": "array", "minItems": 1, "items": { "type": "string", "maxLength": 500 } },
    "recommendation": { "type": "array", "minItems": 1, "items": { "type": "string", "maxLength": 500 } },
    "affected_surface": {
      "type": "object",
      "required": ["type", "id", "file"]
    },
    "provenance": { "type": "array", "minItems": 1 },
    "related_rule_packs": { "type": "array" },
    "runtime_verification": { "type": "object" },
    "review_lifecycle": { "type": "array", "minItems": 1 }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.dev/schemas/spec-app-consistency-audit/i18n-contract.schema.json",
  "title": "spec-app-consistency-audit i18n contract artifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "source_inputs", "consumers", "contract_status", "data_sensitivity", "string_resources", "hardcoded_text_candidates", "locale_risk_candidates"],
  "properties": {
    "schema_version": { "const": "i18n-contract.v1" },
    "artifact_id": { "const": "i18n-contract" },
    "source_inputs": { "type": "array", "minItems": 1 },
    "consumers": { "type": "array", "minItems": 1 },
    "contract_status": { "const": "candidate" },
    "data_sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
    "string_resources": { "type": "array" },
    "hardcoded_text_candidates": { "type": "array" },
    "locale_risk_candidates": { "type": "array" },
    "degraded_modes": { "type": "array" }
  },
  "additionalProperties": true
}

{
  "version": "1.0",
  "tools": [
    {
      "id": "serena",
      "name": "Serena",
      "category": "required",
      "description": "符号级精确编辑引擎，spec-bootstrap Full/Enhanced mode 必需",
      "dependencies": ["uv"],
      "mcp_config": {
        "command": "uvx",
        "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--project-from-cwd", "--context", "__HOST_CONTEXT__", "--open-web-dashboard", "false"]
      },
      "detect": {
        "method": "mcp_config",
        "key": "serena"
      }
    },
    {
      "id": "sequential-thinking",
      "name": "Sequential Thinking",
      "category": "required",
      "description": "动态反思性问题解决，spec-first 全工作流通用依赖",
      "dependencies": ["node"],
      "mcp_config": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
      },
      "detect": {
        "method": "mcp_config",
        "key": "sequential-thinking"
      }
    },
    {
      "id": "context7",
      "name": "Context7",
      "category": "required",
      "description": "最新框架文档查询，spec-first 全工作流通用依赖",
      "dependencies": ["node"],
      "mcp_config": {
        "command": "npx",
        "args": ["-y", "@upstash/context7-mcp"]
      },
      "detect": {
        "method": "mcp_config",
        "key": "context7"
      }
    },
    {
      "id": "playwright",
      "name": "Playwright MCP",
      "category": "optional",
      "description": "前端自动化测试，可选工具",
      "dependencies": ["node"],
      "mcp_config": {
        "command": "npx",
        "args": ["@playwright/mcp@latest"]
      },
      "detect": {
        "method": "mcp_config",
        "key": "playwright"
      }
    }
  ]
}

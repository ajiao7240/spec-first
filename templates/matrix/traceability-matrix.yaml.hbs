featureId: "{{featureId}}"
title: "{{title}}"
generatedAt: "{{timestamp}}"
matrix:
{{#each rows}}
  - id: "{{this.id}}"
    type: "{{this.type}}"
    title: "{{this.title}}"
    status: "{{this.status}}"
{{#if this.upstream}}
    upstream: [{{this.upstream}}]
{{/if}}
{{#if this.downstream}}
    downstream: [{{this.downstream}}]
{{/if}}
{{/each}}

# GitHub Actions — Spec-First CI Pipeline
# Generated by: spec-first init

name: Spec-First CI

on:
  pull_request:
    branches: [{{defaultBranch}}]
  push:
    branches: [{{defaultBranch}}]

jobs:
  spec-first-check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: '{{nodeVersion}}'

      - name: Install dependencies
        run: {{packageManager}} install

      - name: Lint (TypeCheck)
        run: {{packageManager}} run lint

      - name: Unit Tests
        run: {{packageManager}} run test

      - name: Matrix Check
        run: npx spec-first matrix check {{featureId}}

      - name: Gate Check
        run: npx spec-first gate check {{featureId}}

      - name: Doctor
        run: npx spec-first doctor

# GitLab CI — Spec-First CI Pipeline
# Generated by: spec-first init

image: node:{{nodeVersion}}

stages:
  - lint
  - test
  - check

cache:
  paths:
    - node_modules/

before_script:
  - {{packageManager}} install

lint:
  stage: lint
  script:
    - {{packageManager}} run lint

test:
  stage: test
  script:
    - {{packageManager}} run test

matrix-check:
  stage: check
  script:
    - npx spec-first matrix check {{featureId}}

gate-check:
  stage: check
  script:
    - npx spec-first gate check {{featureId}}
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'

doctor:
  stage: check
  script:
    - npx spec-first doctor
  allow_failure: true

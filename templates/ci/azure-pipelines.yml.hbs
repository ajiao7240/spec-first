# Azure Pipelines — Spec-First CI Pipeline
# Generated by: spec-first init

trigger:
  branches:
    include:
      - {{defaultBranch}}

pr:
  branches:
    include:
      - {{defaultBranch}}

pool:
  vmImage: 'ubuntu-latest'

steps:
  - task: NodeTool@0
    inputs:
      versionSpec: '{{nodeVersion}}'

  - script: {{packageManager}} install
    displayName: 'Install dependencies'

  - script: {{packageManager}} run lint
    displayName: 'Lint (TypeCheck)'

  - script: {{packageManager}} run test
    displayName: 'Unit Tests'

  - script: npx spec-first matrix check {{featureId}}
    displayName: 'Matrix Check'

  - script: npx spec-first gate check {{featureId}}
    displayName: 'Gate Check'

  - script: npx spec-first doctor
    displayName: 'Doctor'

{
  "schema_version": "verification-profile.v1",
  "default_profile": "default",
  "profiles": {
    "default": {
      "services": ["spec-first"],
      "checks": ["typecheck", "unit", "smoke", "integration"]
    }
  },
  "services": {
    "spec-first": {
      "path": ".",
      "stack": "node",
      "required": true
    }
  },
  "stacks": {
    "node": {
      "detect": ["package.json"],
      "commands": {
        "typecheck": "npm run typecheck",
        "unit": "npm run test:unit",
        "smoke": "npm run test:smoke",
        "integration": "npm run test:integration"
      },
      "runner_kind": {
        "typecheck": "npm-script",
        "unit": "npm-script",
        "smoke": "npm-script",
        "integration": "npm-script"
      },
      "required_tools": {
        "typecheck": ["node", "npm"],
        "unit": ["node", "npm"],
        "smoke": ["node", "npm"],
        "integration": ["node", "npm"]
      }
    }
  }
}

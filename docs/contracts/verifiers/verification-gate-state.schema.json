{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-first verification gate state",
  "type": "object",
  "required": [
    "schema_version",
    "stage",
    "state_source",
    "overall_status",
    "required_gates",
    "optional_evidence",
    "blockers",
    "evidence_locations",
    "ci_gate"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": ["plan", "work", "review", "verify", "unknown"]
    },
    "state_source": { "type": "string" },
    "overall_status": {
      "type": "string",
      "enum": ["planned", "pending", "blocked", "satisfied", "not-needed"]
    },
    "required_gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gateItem" }
    },
    "optional_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/gateItem" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/blockerItem" }
    },
    "evidence_locations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ci_gate": {
      "type": "object",
      "required": [
        "status",
        "required_gate_count",
        "blocked_required_gate_count",
        "satisfied_required_gate_count"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["planned", "pending", "blocked", "satisfied", "not-needed"]
        },
        "required_gate_count": { "type": "integer", "minimum": 0 },
        "blocked_required_gate_count": { "type": "integer", "minimum": 0 },
        "satisfied_required_gate_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "blockerItem": {
      "type": "object",
      "required": [
        "verifier",
        "target_verifications",
        "setup_hint",
        "prerequisite",
        "kind",
        "reason",
        "detail"
      ],
      "properties": {
        "verifier": { "type": "string" },
        "target_verifications": {
          "type": "array",
          "items": { "type": "string" }
        },
        "setup_hint": { "type": ["string", "null"] },
        "prerequisite": { "type": ["string", "null"] },
        "kind": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] },
        "detail": { "type": ["string", "null"] }
      }
    },
    "gateItem": {
      "type": "object",
      "required": [
        "gate_id",
        "status",
        "fulfillment_mode",
        "verifier",
        "expected_evidence",
        "evidence_locations",
        "blockers"
      ],
      "properties": {
        "gate_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["planned", "pending", "blocked", "satisfied"]
        },
        "fulfillment_mode": {
          "type": "string",
          "enum": ["verifier-skill", "repo-command", "manual-confirmation"]
        },
        "verifier": { "type": ["string", "null"] },
        "expected_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_locations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "verifier",
              "prerequisite",
              "kind",
              "reason",
              "detail",
              "setup_hint"
            ],
            "properties": {
              "verifier": { "type": ["string", "null"] },
              "prerequisite": { "type": ["string", "null"] },
              "kind": { "type": ["string", "null"] },
              "reason": { "type": ["string", "null"] },
              "detail": { "type": ["string", "null"] },
              "setup_hint": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}

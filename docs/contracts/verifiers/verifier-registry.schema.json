{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-first verifier registry",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "verifiers"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "verifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "verifier_id",
          "supported_platforms",
          "prerequisites",
          "evidence_outputs",
          "supported_gate_kinds",
          "supported_evidence_types",
          "availability_checks",
          "invocation_hints"
        ],
        "properties": {
          "verifier_id": { "type": "string" },
          "supported_platforms": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "web",
                "mobile-ios",
                "mobile-android",
                "backend",
                "desktop",
                "cli",
                "shared-contract",
                "unknown"
              ]
            }
          },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supported_gate_kinds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supported_evidence_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "availability_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "prerequisite"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["command", "platform"]
                },
                "command": { "type": "string" },
                "platform": { "type": "string" },
                "prerequisite": { "type": "string" }
              }
            }
          },
          "invocation_hints": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["standalone-skill", "repo-script"]
              },
              "skill_name": { "type": "string" },
              "setup_hint": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first/crg-cli-v1.schema.json",
  "title": "CRG CLI v1 Unified Envelope",
  "$comment": "CRG CLI 统一输出 envelope 约束。所有 17 个子命令共用此 envelope，data 字段类型由 $defs 中各命令定义",
  "type": "object",
  "required": ["schema_version", "generated_at", "repo_root", "degraded", "warnings", "data"],
  "properties": {
    "schema_version": {
      "$comment": "schema 版本标识符，固定为 crg-cli/v1",
      "type": "string",
      "const": "crg-cli/v1"
    },
    "generated_at": {
      "$comment": "输出生成时间，ISO 8601 格式",
      "type": "string",
      "format": "date-time"
    },
    "repo_root": {
      "$comment": "仓库根目录的绝对路径",
      "type": "string"
    },
    "degraded": {
      "$comment": "是否处于降级模式（某些数据源不可用时为 true）",
      "type": "boolean"
    },
    "warnings": {
      "$comment": "警告信息数组，每项至少含 type 字段",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Warning"
      }
    },
    "data": {
      "$comment": "各子命令各自的 data 结构，具体类型见 $defs 中各命令定义"
    }
  },
  "$defs": {
    "Warning": {
      "$comment": "警告对象：至少含 type 字段，可附加任意额外字段",
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "FactItem": {
      "$comment": "事实项：见 crg-fact-item.schema.json 完整定义",
      "type": "object",
      "required": ["name", "file_path", "kind", "confidence", "source_tier"],
      "properties": {
        "name": { "type": "string" },
        "file_path": { "type": "string" },
        "kind": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["Observed", "Inferred", "Unknown"]
        },
        "source_tier": {
          "type": "string",
          "enum": ["crg_ast", "serena_semantic", "grep_glob"]
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inference_reason": {
          "type": "string",
          "enum": [
            "import_analysis",
            "naming_convention",
            "call_graph_traversal",
            "directory_proximity",
            "type_annotation"
          ]
        }
      },
      "if": {
        "properties": { "confidence": { "const": "Inferred" } },
        "required": ["confidence"]
      },
      "then": {
        "required": ["inference_reason"]
      }
    },
    "FlowBrief": {
      "$comment": "flow 简要对象，用于 context 命令的 top_flows",
      "type": "object",
      "required": ["flow_id", "entry_node", "criticality", "node_count"],
      "properties": {
        "flow_id": { "type": "string" },
        "entry_node": { "type": "string" },
        "criticality": { "type": "number" },
        "node_count": { "type": "integer" }
      }
    },
    "CommunityBrief": {
      "$comment": "community 简要对象，用于 context 命令的 top_communities",
      "type": "object",
      "required": ["community_id", "label", "file_count"],
      "properties": {
        "community_id": { "type": "string" },
        "label": { "type": "string" },
        "file_count": { "type": "integer" }
      }
    },
    "CommunityHealth": {
      "$comment": "社区健康状态，四象限：healthy/fragile/isolated/overloaded",
      "type": "object",
      "required": ["status", "density", "independence"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "fragile", "isolated", "overloaded"]
        },
        "density": { "type": "number" },
        "independence": { "type": "number" }
      }
    },
    "BuildData": {
      "$comment": "crg build 命令的 data 结构：图构建结果统计",
      "type": "object",
      "required": ["node_count", "edge_count", "changed_files", "duration_ms"],
      "properties": {
        "node_count": { "type": "integer" },
        "edge_count": { "type": "integer" },
        "changed_files": { "type": "integer" },
        "duration_ms": { "type": "number" }
      }
    },
    "StatsData": {
      "$comment": "crg stats 命令的 data 结构：图统计信息",
      "type": "object",
      "required": ["node_count", "edge_count", "corpus_health", "last_built", "unresolved_edge_count"],
      "properties": {
        "node_count": { "type": "integer" },
        "edge_count": { "type": "integer" },
        "corpus_health": {
          "type": "object",
          "required": ["status", "total_loc"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["small", "optimal", "large"]
            },
            "total_loc": { "type": "integer" }
          }
        },
        "last_built": {
          "type": "string",
          "format": "date-time"
        },
        "unresolved_edge_count": { "type": "integer" }
      }
    },
    "ContextData": {
      "$comment": "crg context 命令的 data 结构：仓库整体上下文摘要",
      "type": "object",
      "required": ["top_flows", "top_communities", "top_hubs", "summary"],
      "properties": {
        "top_flows": {
          "type": "array",
          "items": { "$ref": "#/$defs/FlowBrief" }
        },
        "top_communities": {
          "type": "array",
          "items": { "$ref": "#/$defs/CommunityBrief" }
        },
        "top_hubs": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        },
        "summary": { "type": "string" }
      }
    },
    "QueryData": {
      "$comment": "crg query 命令的 data 结构：按 pattern 查询匹配节点列表",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        }
      }
    },
    "ImpactData": {
      "$comment": "crg impact 命令的 data 结构：变更影响分析结果",
      "type": "object",
      "required": ["impacted_nodes", "blast_radius"],
      "properties": {
        "impacted_nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        },
        "blast_radius": { "type": "integer" }
      }
    },
    "LargeFunctionsData": {
      "$comment": "crg large-functions 命令的 data 结构：超大函数/方法列表",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file_path", "loc", "kind"],
            "properties": {
              "name": { "type": "string" },
              "file_path": { "type": "string" },
              "loc": { "type": "integer" },
              "kind": {
                "type": "string",
                "enum": ["function", "method"]
              }
            }
          }
        }
      }
    },
    "SearchData": {
      "$comment": "crg search 命令的 data 结构：全文/语义搜索结果",
      "type": "object",
      "required": ["results"],
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["node_id", "name", "file_path", "kind", "snippet"],
            "properties": {
              "node_id": { "type": "string" },
              "name": { "type": "string" },
              "file_path": { "type": "string" },
              "kind": { "type": "string" },
              "snippet": { "type": "string" }
            }
          }
        }
      }
    },
    "FlowsData": {
      "$comment": "crg flows 命令的 data 结构：所有 flow 列表（简要）",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/FlowBrief" }
        }
      }
    },
    "FlowData": {
      "$comment": "crg flow 命令的 data 结构：单个 flow 详情（含节点列表）",
      "type": "object",
      "required": ["flow_id", "entry_node", "criticality", "nodes"],
      "properties": {
        "flow_id": { "type": "string" },
        "entry_node": { "type": "string" },
        "criticality": { "type": "number" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        }
      }
    },
    "AffectedFlowsData": {
      "$comment": "crg affected-flows 命令的 data 结构：受变更影响的 flow 列表",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["flow_id", "entry_node", "affected_nodes"],
            "properties": {
              "flow_id": { "type": "string" },
              "entry_node": { "type": "string" },
              "affected_nodes": {
                "type": "array",
                "items": { "$ref": "#/$defs/FactItem" }
              }
            }
          }
        }
      }
    },
    "CommunitiesData": {
      "$comment": "crg communities 命令的 data 结构：社区列表 + 聚合统计",
      "type": "object",
      "required": ["items", "stats"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["community_id", "label", "file_count", "health"],
            "properties": {
              "community_id": { "type": "string" },
              "label": { "type": "string" },
              "file_count": { "type": "integer" },
              "health": { "$ref": "#/$defs/CommunityHealth" }
            }
          }
        },
        "stats": {
          "type": "object",
          "required": ["total", "by_status"],
          "properties": {
            "total": { "type": "integer" },
            "by_status": {
              "type": "object",
              "required": ["healthy", "fragile", "isolated", "overloaded"],
              "properties": {
                "healthy": { "type": "integer" },
                "fragile": { "type": "integer" },
                "isolated": { "type": "integer" },
                "overloaded": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "CommunityData": {
      "$comment": "crg community 命令的 data 结构：单个社区详情（含成员节点）",
      "type": "object",
      "required": ["community_id", "label", "file_count", "health", "members"],
      "properties": {
        "community_id": { "type": "string" },
        "label": { "type": "string" },
        "file_count": { "type": "integer" },
        "health": { "$ref": "#/$defs/CommunityHealth" },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        }
      }
    },
    "ArchitectureData": {
      "$comment": "crg architecture 命令的 data 结构：架构全局视图（hub 节点 + 跨社区边）",
      "type": "object",
      "required": ["hub_nodes", "cross_community_edges"],
      "properties": {
        "hub_nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        },
        "cross_community_edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target", "kind"],
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "kind": { "type": "string" }
            }
          }
        }
      }
    },
    "SurprisingConnectionsData": {
      "$comment": "crg surprising-connections 命令的 data 结构：意外连接列表",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target", "score", "reasons"],
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "score": { "type": "integer" },
              "reasons": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "GodNodesData": {
      "$comment": "crg god-nodes 命令的 data 结构：上帝节点（过度耦合节点）列表",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        }
      }
    },
    "DetectChangesData": {
      "$comment": "crg detect-changes 命令的 data 结构：变更风险检测结果",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "risk_level", "functions"],
            "properties": {
              "file": { "type": "string" },
              "risk_level": {
                "type": "string",
                "enum": ["High", "Medium", "Low"]
              },
              "functions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "risk_level"],
                  "properties": {
                    "name": { "type": "string" },
                    "risk_level": {
                      "type": "string",
                      "enum": ["High", "Medium", "Low"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "ReviewContextData": {
      "$comment": "crg review-context 命令的 data 结构：PR review 上下文（变更摘要 + 受影响节点 + 候选测试）",
      "type": "object",
      "required": ["diff_summary", "affected_nodes", "candidate_tests"],
      "properties": {
        "diff_summary": { "type": "string" },
        "affected_nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/FactItem" }
        },
        "candidate_tests": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "inferred"],
            "properties": {
              "file": { "type": "string" },
              "inferred": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-graph-bootstrap verification-profile",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "profile_id",
    "platforms",
    "languages",
    "detected_test_frameworks",
    "required_gates",
    "optional_gates",
    "verifier_hints",
    "environment_prerequisites",
    "fallback_reason"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "profile_id": { "type": "string" },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "web",
          "mobile-ios",
          "mobile-android",
          "backend",
          "desktop",
          "cli",
          "shared-contract",
          "unknown"
        ]
      }
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "detected_test_frameworks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "scope",
          "required",
          "reason",
          "suggested_commands",
          "evidence_type"
        ],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "scope": { "type": "string" },
          "required": { "type": "boolean" },
          "reason": { "type": "string" },
          "suggested_commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_type": { "type": "string" }
        }
      }
    },
    "optional_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "scope",
          "required",
          "reason",
          "suggested_commands",
          "evidence_type"
        ],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "scope": { "type": "string" },
          "required": { "type": "boolean" },
          "reason": { "type": "string" },
          "suggested_commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_type": { "type": "string" }
        }
      }
    },
    "verifier_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "verifier",
          "platforms",
          "available",
          "prerequisites",
          "evidence_outputs"
        ],
        "properties": {
          "verifier": { "type": "string" },
          "platforms": {
            "type": "array",
            "items": { "type": "string" }
          },
          "available": { "type": "boolean" },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_outputs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "environment_prerequisites": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "fallback_reason": { "type": ["string", "null"] }
  }
}

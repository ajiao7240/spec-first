{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-graph-bootstrap database-routing",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "discovery_strategy",
    "hint_summary",
    "runtime_capabilities",
    "candidate_readiness"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "discovery_strategy": {
      "type": "string",
      "enum": ["llm-led"]
    },
    "hint_summary": {
      "type": "object",
      "required": [
        "database_hint_count",
        "schema_hint_count",
        "db_type_hints",
        "config_sources",
        "schema_sources",
        "env_key_hints"
      ],
      "properties": {
        "database_hint_count": { "type": "integer" },
        "schema_hint_count": { "type": "integer" },
        "db_type_hints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "config_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "schema_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env_key_hints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "runtime_capabilities": {
      "type": "object",
      "required": [
        "available_readonly_routes"
      ],
      "properties": {
        "available_readonly_routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["route", "available", "reason"],
            "properties": {
              "route": {
                "type": "string",
                "enum": ["mysql-cli"]
              },
              "available": { "type": "boolean" },
              "reason": {
                "type": "string",
                "enum": ["tool-present", "tool-missing"]
              }
            }
          }
        }
      }
    },
    "candidate_readiness": {
      "type": "object",
      "required": [
        "candidates",
        "resolved_env_keys",
        "missing_env_keys"
      ],
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "connection_name",
              "db_type",
              "credential_keys",
              "resolved_credential_keys",
              "missing_credential_keys",
              "supported_readonly_routes",
              "available_readonly_routes",
              "route_availability",
              "has_available_readonly_route",
              "has_complete_env_hints",
              "can_readonly_introspect",
              "blockers"
            ],
            "properties": {
              "connection_name": { "type": "string" },
              "config_source": { "type": ["string", "null"] },
              "db_type": { "type": "string" },
              "credential_keys": {
                "type": "array",
                "items": { "type": "string" }
              },
              "resolved_credential_keys": {
                "type": "array",
                "items": { "type": "string" }
              },
              "missing_credential_keys": {
                "type": "array",
                "items": { "type": "string" }
              },
              "supported_readonly_routes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["mysql-cli"]
                }
              },
              "available_readonly_routes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["mysql-cli"]
                }
              },
              "route_availability": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["route", "available", "reason"],
                  "properties": {
                    "route": {
                      "type": "string",
                      "enum": ["mysql-cli"]
                    },
                    "available": { "type": "boolean" },
                    "reason": {
                      "type": "string",
                      "enum": ["tool-present", "tool-missing"]
                    }
                  }
                }
              },
              "has_available_readonly_route": { "type": "boolean" },
              "has_complete_env_hints": { "type": "boolean" },
              "can_readonly_introspect": { "type": "boolean" },
              "blockers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["kind", "reason"],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["runtime-capability", "env-availability"]
                    },
                    "reason": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "resolved_env_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_env_keys": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "recommended_action": {
      "type": "string",
      "enum": ["llm-readonly-introspect", "llm-inspect-repo", "not-needed"]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "reason"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["runtime-capability", "env-availability"]
          },
          "reason": { "type": "string" }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-graph-bootstrap database-routing",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "discovery_strategy",
    "hint_summary",
    "runtime_capabilities",
    "recommended_action",
    "blockers"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "discovery_strategy": {
      "type": "string",
      "enum": ["llm-led"]
    },
    "hint_summary": {
      "type": "object",
      "required": [
        "database_hint_count",
        "schema_hint_count",
        "db_type_hints",
        "config_sources",
        "schema_sources",
        "env_key_hints"
      ],
      "properties": {
        "database_hint_count": { "type": "integer" },
        "schema_hint_count": { "type": "integer" },
        "db_type_hints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "config_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "schema_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env_key_hints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "runtime_capabilities": {
      "type": "object",
      "required": [
        "available_readonly_routes",
        "resolved_env_keys",
        "missing_env_keys"
      ],
      "properties": {
        "available_readonly_routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["route", "available", "reason"],
            "properties": {
              "route": {
                "type": "string",
                "enum": ["mysql-cli"]
              },
              "available": { "type": "boolean" },
              "reason": {
                "type": "string",
                "enum": ["tool-present", "tool-missing"]
              }
            }
          }
        },
        "resolved_env_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_env_keys": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "recommended_action": {
      "type": "string",
      "enum": ["llm-readonly-introspect", "llm-inspect-repo", "not-needed"]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "reason"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["runtime-capability", "env-availability"]
          },
          "reason": { "type": "string" }
        }
      }
    }
  }
}

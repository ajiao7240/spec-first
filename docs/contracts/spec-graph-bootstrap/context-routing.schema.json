{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-graph-bootstrap context-routing",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "always",
    "stages",
    "selection_rules",
    "advice"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "always": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stages": {
      "type": "object",
      "required": ["plan", "work", "review", "unknown"],
      "properties": {
        "plan": { "type": "array", "items": { "type": "string" } },
        "work": { "type": "array", "items": { "type": "string" } },
        "review": { "type": "array", "items": { "type": "string" } },
        "unknown": { "type": "array", "items": { "type": "string" } }
      }
    },
    "selection_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "inject"],
        "properties": {
          "condition": { "type": "string" },
          "inject": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "advice": {
      "type": "object",
      "required": ["plan", "work", "review"],
      "properties": {
        "plan": { "type": "string" },
        "work": { "type": "string" },
        "review": { "type": "string" }
      }
    }
  }
}

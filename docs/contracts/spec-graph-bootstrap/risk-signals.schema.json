{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-graph-bootstrap risk-signals",
  "type": "object",
  "required": ["signals", "crg_metrics"],
  "properties": {
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "severity", "summary"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "severity": { "type": "string" },
          "summary": { "type": "string" },
          "line_count": { "type": "number" }
        }
      }
    },
    "crg_metrics": {
      "type": "object",
      "required": ["source", "signal_count"],
      "properties": {
        "source": { "type": "string" },
        "signal_count": { "type": "number" }
      }
    }
  }
}

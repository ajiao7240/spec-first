{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRG Workspace Config",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "const": "workspace-config/v1"
    },
    "include_roots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude_globs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "max_depth": {
      "type": "integer"
    }
  }
}

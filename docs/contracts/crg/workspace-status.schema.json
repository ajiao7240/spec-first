{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRG Workspace Status",
  "type": "object",
  "required": [
    "schema_version",
    "workspace_root",
    "generated_at",
    "scope",
    "summary",
    "children",
    "stale_entries",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "workspace-status/v1"
    },
    "workspace_root": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "summary": {
      "type": "object",
      "required": ["child_count", "candidate_count", "ready_count", "missing_count", "degraded_count"],
      "properties": {
        "child_count": {
          "type": "integer"
        },
        "candidate_count": {
          "type": "integer"
        },
        "ready_count": {
          "type": "integer"
        },
        "missing_count": {
          "type": "integer"
        },
        "degraded_count": {
          "type": "integer"
        }
      }
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "repo_root",
          "git_root",
          "relative_path",
          "relationship",
          "candidate",
          "readiness",
          "graph",
          "signals",
          "limitations"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "repo_root": {
            "type": "string"
          },
          "git_root": {
            "type": "string"
          },
          "relative_path": {
            "type": "string"
          },
          "relationship": {
            "enum": ["root_repo", "nested_independent_repo", "submodule", "worktree"]
          },
          "candidate": {
            "type": "boolean"
          },
          "readiness": {
            "enum": ["ready", "missing", "degraded", "unavailable"]
          },
          "graph": {
            "type": "object",
            "required": ["state", "active_db_path", "stats", "freshness", "capabilities"],
            "properties": {
              "state": {
                "enum": ["ready", "missing", "degraded", "unavailable"]
              },
              "active_db_path": {
                "type": ["string", "null"]
              },
              "stats": {
                "type": "object"
              },
              "freshness": {
                "type": "object"
              },
              "capabilities": {
                "type": "object"
              }
            }
          },
          "signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "message"],
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "stale_entries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-first.local/contracts/crg/retrieval-eval.schema.json",
  "title": "CRG Retrieval Evaluation",
  "type": "object",
  "required": ["schema_version", "fixtures", "summary"],
  "properties": {
    "schema_version": { "const": "retrieval-eval/v1" },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fixture_id", "mrr", "recall_at_k", "precision", "recall", "f1"]
      }
    },
    "summary": {
      "type": "object",
      "required": ["fixture_count", "mean_mrr", "mean_recall_at_k"]
    }
  },
  "additionalProperties": true
}

{
  "name": "spec-first",
  "version": "1.5.1",
  "description": "AI-assisted work framework for Claude Code with a npm CLI entrypoint",
  "type": "commonjs",
  "bin": {
    "spec-first": "./bin/spec-first.js"
  },
  "scripts": {
    "test:unit": "bash tests/unit/developer.sh && bash tests/unit/lang-policy.sh && bash tests/unit/mcp-setup.sh && bash tests/unit/version-reminder.sh && npx jest tests/unit --runInBand",
    "test:smoke": "bash tests/smoke/install-local.sh && bash tests/smoke/cli.sh",
    "test:integration": "bash tests/integration/e2e.sh",
    "test:e2e:crg": "bash tests/e2e/crg-all-commands.sh && bash tests/e2e/crg-sqlite-audit.sh",
    "test": "npm run test:unit && npm run test:smoke && npm run test:integration && npm run test:e2e:crg",
    "test:jest": "jest",
    "test:release": "bash tests/smoke/install-tarball.sh",
    "postinstall": "node bin/postinstall.js"
  },
  "files": [
    "bin/",
    "src/",
    "vendor/",
    ".claude-plugin/",
    "agents/",
    "skills/",
    "templates/",
    "README.md"
  ],
  "keywords": [
    "spec-first",
    "harness-engineering",
    "claude-code",
    "ai-workflow-framework",
    "specification-driven",
    "knowledge-compound",
    "ai-code-review",
    "iterative-improvement",
    "context-engineering",
    "developer-harness"
  ],
  "author": "spec-first",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunrain520/spec-first.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "~12.6.0",
    "ignore": "^5.0.0",
    "simple-git": "~3.0.0",
    "tree-sitter": "~0.21.0",
    "tree-sitter-c": "~0.21.4",
    "tree-sitter-c-sharp": "~0.23.1",
    "tree-sitter-cpp": "~0.21.0",
    "tree-sitter-go": "~0.23.0",
    "tree-sitter-java": "~0.23.0",
    "tree-sitter-javascript": "~0.23.0",
    "tree-sitter-kotlin": "~0.3.0",
    "tree-sitter-objc": "file:./vendor/tree-sitter-objc",
    "tree-sitter-php": "~0.23.0",
    "tree-sitter-python": "~0.21.0",
    "tree-sitter-ruby": "~0.23.0",
    "tree-sitter-rust": "~0.21.0",
    "tree-sitter-scala": "~0.24.0",
    "tree-sitter-swift": "file:./vendor/tree-sitter-swift",
    "tree-sitter-typescript": "~0.23.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "overrides": {
    "tree-sitter": "$tree-sitter"
  }
}

{
  "name": "spec-first",
  "version": "1.5.3",
  "description": "AI coding workflow CLI for spec-driven engineering, spec-driven development, and harness engineering on Claude Code and Codex",
  "type": "commonjs",
  "bin": {
    "spec-first": "./bin/spec-first.js"
  },
  "scripts": {
    "lint:skill-entrypoints": "node scripts/lint-skill-entrypoints.js",
    "typecheck": "node --check bin/spec-first.js && node --check bin/postinstall.js && node --check scripts/lint-skill-entrypoints.js && node --check scripts/run-ai-dev-quality-gate.js && node --check scripts/run-crg-benchmark-evidence.js && node --check scripts/update-crg-baselines.js",
    "build": "npm pack --dry-run",
    "release:publish": "node scripts/release-publish.cjs",
    "test:unit": "bash tests/unit/developer.sh && bash tests/unit/lang-policy.sh && bash tests/unit/setup.sh && bash tests/unit/mcp-setup.sh && bash tests/unit/version-reminder.sh && npx jest tests/unit --runInBand",
    "test:smoke": "bash tests/smoke/install-local.sh && bash tests/smoke/cli.sh",
    "test:integration": "npx jest tests/integration/verification-gate.integration.test.js --runInBand && bash tests/integration/e2e.sh",
    "test:ai-dev:gate": "node scripts/run-ai-dev-quality-gate.js",
    "test:e2e:crg": "bash tests/e2e/crg-all-commands.sh && bash tests/e2e/crg-sqlite-audit.sh",
    "test:crg:gate": "node benchmarks/regression/run-regression.js",
    "test:crg:benchmark-evidence": "node scripts/run-crg-benchmark-evidence.js",
    "test:crg:benchmarks": "node benchmarks/review/run-review-benchmark.js && node benchmarks/repo-qa/run-repo-qa.js && node benchmarks/context-efficiency/run-context-efficiency.js",
    "test": "npm run test:unit && npm run test:smoke && npm run test:integration && npm run test:e2e:crg",
    "test:jest": "jest",
    "test:release": "npm run test:release:governance && npm run test:release:install",
    "test:release:governance": "bash tests/smoke/release-dual-host-governance.sh",
    "test:release:install": "bash tests/smoke/install-tarball.sh",
    "postinstall": "node bin/postinstall.js"
  },
  "files": [
    "bin/",
    "src/",
    "vendor/",
    ".claude-plugin/",
    "agents/",
    "skills/",
    "templates/",
    "README.md"
  ],
  "keywords": [
    "spec-first",
    "ai-coding-workflow",
    "spec-driven-engineering",
    "spec-driven-development",
    "harness-engineering",
    "knowledge-compound",
    "ai-code-review",
    "context-engineering",
    "ai-engineering",
    "engineering-workflow",
    "developer-workflow",
    "multi-agent-workflow",
    "agent-workflow",
    "claude-code",
    "codex"
  ],
  "author": "spec-first",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunrain520/spec-first.git"
  },
  "homepage": "https://github.com/sunrain520/spec-first#readme",
  "bugs": {
    "url": "https://github.com/sunrain520/spec-first/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "~12.6.0",
    "ignore": "^5.0.0",
    "simple-git": "~3.0.0",
    "tree-sitter": "~0.21.0",
    "tree-sitter-c": "~0.21.4",
    "tree-sitter-c-sharp": "~0.23.1",
    "tree-sitter-cpp": "~0.21.0",
    "tree-sitter-go": "~0.23.0",
    "tree-sitter-java": "~0.23.0",
    "tree-sitter-javascript": "~0.23.0",
    "tree-sitter-kotlin": "~0.3.0",
    "tree-sitter-objc": "file:./vendor/tree-sitter-objc",
    "tree-sitter-php": "~0.23.0",
    "tree-sitter-python": "~0.21.0",
    "tree-sitter-ruby": "~0.23.0",
    "tree-sitter-rust": "~0.21.0",
    "tree-sitter-scala": "~0.24.0",
    "tree-sitter-swift": "file:./vendor/tree-sitter-swift",
    "tree-sitter-typescript": "~0.23.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "overrides": {
    "tree-sitter": "$tree-sitter"
  }
}

{
  "name": "spec-first",
  "version": "0.1.0",
  "description": "Specification-driven development process engine for AI-era software development",
  "type": "module",
  "bin": {
    "spec-first": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "bench": "vitest bench",
    "viewer:start": "node scripts/stage-viewer/server.js --project-root . --port 0",
    "viewer:bootstrap": "node scripts/stage-viewer/bootstrap.js --open",
    "codex:autostart:install": "bash scripts/codex/install-codex-autostart.sh",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/postinstall.js || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "spec-first",
    "specification",
    "traceability",
    "development-process"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "skills",
    "templates",
    "README.md",
    "scripts/stage-viewer",
    "scripts/codex"
  ],
  "exports": {
    ".": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "update-notifier": "^7.0.0"
  }
}

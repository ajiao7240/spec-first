{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter spec-first build",
    "test": "pnpm --filter spec-first test",
    "lint": "pnpm --filter spec-first lint",
    "typecheck": "pnpm --filter spec-first typecheck",
    "snapshot:create": "bash scripts/create-snapshot.sh",
    "snapshot:diff": "bash scripts/diff-snapshots.sh",
    "snapshot:test-rollback": "bash scripts/test-rollback.sh",
    "skill-docs:refactor": "bash scripts/refactor-skill-docs.sh",
    "skill-docs:validate": "bash scripts/validate-skill-docs.sh",
    "skill-docs:preview": "bash scripts/preview-skill-changes.sh",
    "release": "pnpm --filter spec-first release",
    "release:minor": "pnpm --filter spec-first release:minor",
    "release:beta": "pnpm --filter spec-first release:beta",
    "release:rc": "pnpm --filter spec-first release:rc"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}

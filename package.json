{
  "name": "spec-first",
  "version": "0.5.65",
  "description": "Specification-driven development process engine for AI-era software development",
  "type": "module",
  "bin": {
    "spec-first": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "bench": "vitest bench",
    "viewer:start": "node scripts/stage-viewer/server.js --project-root . --port 0",
    "viewer:bootstrap": "node scripts/stage-viewer/bootstrap.js --open",
    "codex:autostart:install": "bash scripts/codex/install-codex-autostart.sh",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/postinstall.js || true",
    "preuninstall": "node dist/preuninstall.js || true",
    "contract:check": "echo \"No API contract for Skill optimization\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "spec-first",
    "specification",
    "traceability",
    "development-process"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "skills",
    "templates",
    "README.md",
    "scripts/stage-viewer",
    "scripts/codex"
  ],
  "exports": {
    ".": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "semver": "^7.7.4",
    "update-notifier": "^7.0.0"
  },
  "pnpm": {
    "overrides": {
      "rollup": "^4.59.0",
      "minimatch": "^3.1.3",
      "esbuild": "^0.27.3"
    }
  }
}

{
  "schemaVersion": 1,
  "name": "spec-first",
  "version": "1.3.10",
  "description": "AI-assisted work framework for Claude Code with plugin-style packaged assets",
  "repository": "https://github.com/sunrain520/spec-first.git",
  "directories": {
    "commands": "templates/claude/commands/spec",
    "skills": "skills",
    "agents": "agents"
  },
  "commands": [
    {
      "name": "brainstorm",
      "filename": "brainstorm.md",
      "description": "Run the Spec-First brainstorm workflow",
      "argumentHint": "[feature idea or problem]",
      "skill": "spec-brainstorm"
    },
    {
      "name": "plan",
      "filename": "plan.md",
      "description": "Run the Spec-First planning workflow",
      "argumentHint": "[requirements doc path or topic]",
      "skill": "spec-plan"
    },
    {
      "name": "work",
      "filename": "work.md",
      "description": "Run the Spec-First execution workflow",
      "argumentHint": "[plan file path]",
      "skill": "spec-work"
    },
    {
      "name": "review",
      "filename": "review.md",
      "description": "Run the Spec-First review workflow",
      "argumentHint": "[branch, PR, or change summary]",
      "skill": "spec-review"
    },
    {
      "name": "compound",
      "filename": "compound.md",
      "description": "Run the Spec-First knowledge capture workflow",
      "argumentHint": "[brief problem context]",
      "skill": "spec-compound"
    }
  ],
  "extensibleDirectories": {
    "hooks": "hooks",
    "mcpServers": ".mcp.json"
  }
}

{
  "schemaVersion": 1,
  "name": "spec-first",
  "version": "1.5.1",
  "description": "AI-assisted work framework for Claude Code with plugin-style packaged assets",
  "repository": "https://github.com/sunrain520/spec-first.git",
  "directories": {
    "commands": "templates/claude/commands/spec",
    "skills": "skills",
    "agents": "agents"
  },
  "commands": [
    {
      "name": "ideate",
      "filename": "ideate.md",
      "description": "Run the Spec-First ideation workflow",
      "argumentHint": "[feature, focus area, or constraint]",
      "skill": "spec-ideate"
    },
    {
      "name": "brainstorm",
      "filename": "brainstorm.md",
      "description": "Run the Spec-First brainstorm workflow",
      "argumentHint": "[feature idea or problem]",
      "skill": "spec-brainstorm"
    },
    {
      "name": "plan",
      "filename": "plan.md",
      "description": "Run the Spec-First planning workflow",
      "argumentHint": "[requirements doc path or topic]",
      "skill": "spec-plan"
    },
    {
      "name": "work",
      "filename": "work.md",
      "description": "Run the Spec-First execution workflow",
      "argumentHint": "[plan file path]",
      "skill": "spec-work"
    },
    {
      "name": "review",
      "filename": "review.md",
      "description": "Run the Spec-First review workflow",
      "argumentHint": "[branch, PR, or change summary]",
      "skill": "spec-review"
    },
    {
      "name": "compound",
      "filename": "compound.md",
      "description": "Run the Spec-First knowledge capture workflow",
      "argumentHint": "[brief problem context]",
      "skill": "spec-compound"
    },
    {
      "name": "bootstrap",
      "filename": "bootstrap.md",
      "description": "Stage-0 project context bootstrap workflow",
      "argumentHint": "[target repo path or context slug]",
      "skill": "spec-bootstrap"
    },
    {
      "name": "graph-bootstrap",
      "filename": "graph-bootstrap.md",
      "description": "Stage-0 graph bootstrap validation workflow",
      "argumentHint": "[target repo path or context slug]",
      "skill": "spec-graph-bootstrap"
    },
    {
      "name": "mcp-setup",
      "filename": "mcp-setup.md",
      "description": "One-click MCP tools installation and configuration for spec-first workflows",
      "argumentHint": "[quick|custom]",
      "skill": "mcp-setup"
    }
  ],
  "extensibleDirectories": {
    "hooks": "hooks",
    "mcpServers": ".mcp.json"
  }
}
